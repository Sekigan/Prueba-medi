# Modelos Pydantic
class ProductItem(BaseModel):
    product_id: int
    quantity: int

class OrderRequest(BaseModel):
    customer: int
    products: List[ProductItem]


@app.post("/orders/")
def create_order(order: OrderRequest, db: Session = Depends(db.get_db)):
    """Crear nueva orden"""
    # Verificar cliente
    customer = customer_entity.get_customer(db, order.customer)
    if not customer:
        raise HTTPException(404, f"Cliente {order.customer} no encontrado")
    
    # Verificar productos y stock
    items_to_create = []
    total = 0
    all_sufficient = True
    insufficient_products = []
# Antes de cualquier operación, define:
    products_info = []          # Para guardar info de productos
    items_created = []          # Para items de orden
    movements_created = []      # Para movimientos

    for item in order.products:
        product = product_entity.get_product(db, item.product_id)
        if not product:
            raise HTTPException(404, f"Producto {item.product_id} no encontrado")

    # 3. VERIFICAR PRODUCTOS
    for item in order.products:
        product = product_entity.get_product(db, item.product_id)
        if not product:
            raise HTTPException(404, f"Producto {item.product_id} no encontrado")
        
        sufficient = product.stock >= item.quantity
        
        if not sufficient:
            all_sufficient = False
            insufficient_products.append({
                "product_id": item.product_id,
                "name": product.name,
                "requested": item.quantity,
                "available": product.stock
            })
        
        products_info.append({
            "product": product,
            "quantity": item.quantity,
            "sufficient": sufficient
        })
    
    # 4. DETERMINAR ESTADO
    order_status = "confirmed" if all_sufficient else "rejected"
    
    # 5. CREAR ORDEN EN BD
    db_order = models.Order(
        customer_id=order.customer,  # ✅ USANDO 'order'
        status=order_status,
        total=0
    )
    db.add(db_order)
    db.flush()
    
    total = 0
    items_created = []
    movements_created = []
    
    # 6. PROCESAR PRODUCTOS
    for info in products_info:
        product = info["product"]
        quantity = info["quantity"]
        sufficient = info["sufficient"]
        
        # Guardar stock anterior
        old_stock = product.stock
        
        # Crear order item (siempre)
        db_item = models.Order_item(
            order_id=db_order.order_id,
            product_id=product.product_id,
            quantity=quantity,
            unit_price=product.price
        )
        db.add(db_item)
        items_created.append(db_item)
        
        # Si hay stock suficiente
        if sufficient:
            # Actualizar stock
            product.stock -= quantity
            
            # Registrar movimiento
            db_movement = models.Inventory_movement(
                product_id=product.product_id,
                movement_type="salida",
                quantity=-quantity,
                previous_stock=old_stock,
                new_stock=product.stock,
                reference_id=db_order.order_id,
                notes=f"Venta orden #{db_order.order_id}"
            )
            db.add(db_movement)
            movements_created.append(db_movement)
            
            # Sumar al total
            total += product.price * quantity
    
    # 7. ACTUALIZAR TOTAL
    db_order.total = total
    
    # 8. GUARDAR TODO
    db.commit()
    
    # 9. PREPARAR RESPUESTA
    response = {
        "message": f"Orden creada - Estado: {order_status}",
        "order": {
            "order_id": db_order.order_id,
            "customer": {
                "id": customer.id,
                "name": customer.name,
                "email": customer.email
            },
            "date": db_order.order_date.isoformat() if db_order.order_date else None,
            "status": db_order.status,
            "total": float(db_order.total)
        },
        "products": []
    }
    
    # Agregar productos a la respuesta
    for info in products_info:
        product = info["product"]
        quantity = info["quantity"]
        sufficient = info["sufficient"]
        
        price_float = float(product.price)
        subtotal = price_float * quantity
        
        response["products"].append({
            "product_id": product.product_id,
            "name": product.name,
            "quantity": quantity,
            "price": price_float,
            "subtotal": subtotal if sufficient else 0,
            "condition_met": sufficient
        })
    
    # Agregar movimientos
    if movements_created:
        response["inventory_movements"] = []
        for movement in movements_created:
            response["inventory_movements"].append({
                "movement_id": movement.movement_id,
                "product_id": movement.product_id,
                "type": movement.movement_type,
                "quantity": movement.quantity,
                "previous_stock": movement.previous_stock,
                "new_stock": movement.new_stock
            })
    
    # Agregar advertencia
    if insufficient_products:
        response["warning"] = {
            "message": "Algunos productos no tenían stock suficiente",
            "insufficient_products": insufficient_products
        }
    
    return response





