#INVENTORY_MOVEMENT
@app.get("/orders/{order_id}/movements")
def get_order_movements(order_id: int, db: Session = Depends(db.get_db)):
    """Ver todos los movimientos de inventario de una orden"""

    # Buscar movimientos por reference_id (que guarda el order_id)
    movements = db.query(models.Inventory_movement).filter(
        models.Inventory_movement.reference_id == order_id
    ).all()

    # También buscar por notas como respaldo
    if not movements:
        movements = db.query(models.Inventory_movement).filter(
            models.Inventory_movement.notes.like(f"%orden {order_id}%")
        ).all()

    result = []
    for m in movements:
        product = product_entity.get_product(db, m.product_id)
        result.append({
            "movement_id": m.movement_id,
            "product": {
                "id": m.product_id,
                "name": product.name if product else "Desconocido"
            },
            "type": m.movement_type,
            "quantity": m.quantity,
            "previous_stock": m.previous_stock,
            "new_stock": m.new_stock,
            "date": m.movement_date,
            "reference_id": m.reference_id  # Aquí está el order_id
        })

    return {
        "order_id": order_id,
        "movements": result,
        "total_movements": len(result)
    }
