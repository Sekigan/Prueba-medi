class ProductUpdate(BaseModel):
    name: Optional[str] = None
    product_code: Optional[int] = None
    price: Optional[float] = None
    stock: Optional[int] = None
    category: Optional[str] = None

# Actualizar PRODUCT
@app.patch("/products/{product_id}")
def patch_product(
    product_id: int,
    product_update: ProductUpdate,  # Usando el modelo Pydantic
    db: Session = Depends(db.get_db)
):
    """
    Actualización parcial con PATCH
    
    Ejemplo de body:
    {
        "name": "Laptop Gaming",
        "price": 25000
    }
    """
    # Verificar que existe
    product = product_entity.get_product(db, product_id)
    if not product:
        raise HTTPException(404, "Producto no encontrado")
    
    # Verificar código único si se actualiza
    if product_update.product_code and product_update.product_code != product.product_code:
        if product_entity.get_product_by_code(db, product_update.product_code):
            raise HTTPException(400, "Código ya existe")
    
    # Actualizar solo campos proporcionados
    if product_update.name is not None:
        product.name = product_update.name
    if product_update.product_code is not None:
        product.product_code = product_update.product_code
    if product_update.price is not None:
        product.price = product_update.price
    if product_update.category is not None:
        product.category = product_update.category
    if product_update.stock is not None:
        stock_change = product_update.stock - product.stock
        if stock_change != 0:
            try:
                product_entity.update_product_stock(db, product_id, stock_change)
            except ValueError as e:
                raise HTTPException(400, str(e))
    
    db.commit()
    db.refresh(product)
    
    return {
        "message": "Producto actualizado",
        "product": {
            "product_id": product.product_id,
            "name": product.name,
            "product_code": product.product_code,
            "price": float(product.price),
            "stock": product.stock,
            "category": product.category
        }
    }
